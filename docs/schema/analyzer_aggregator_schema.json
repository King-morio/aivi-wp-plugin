{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aivi.example.com/schemas/analyzer_aggregator_schema.json",
  "title": "AiVI Analyzer Aggregator Response",
  "description": "Schema for the aggregated analysis results from AiVI orchestrator",
  "type": "object",
  "required": [
    "run_id",
    "scores",
    "checks",
    "metadata"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this analysis run"
    },
    "scores": {
      "type": "object",
      "description": "Overall AEO and GEO scores",
      "required": ["AEO", "GEO"],
      "properties": {
        "AEO": {
          "type": "integer",
          "minimum": 0,
          "maximum": 55,
          "description": "Answer Engine Optimization score (0-55)"
        },
        "GEO": {
          "type": "integer",
          "minimum": 0,
          "maximum": 45,
          "description": "Generative Engine Optimization score (0-45)"
        }
      }
    },
    "checks": {
      "type": "array",
      "description": "Array of all performed checks",
      "items": {
        "$ref": "#/$defs/check"
      }
    },
    "highlights": {
      "type": "array",
      "description": "Content highlights with suggestions",
      "items": {
        "$ref": "#/$defs/highlight"
      }
    },
    "schema_suggestions": {
      "type": "object",
      "description": "Generated schema suggestions",
      "properties": {
        "faq_jsonld": {
          "$ref": "#/$defs/faq_schema"
        },
        "article_jsonld": {
          "$ref": "#/$defs/article_schema"
        },
        "organization_jsonld": {
          "$ref": "#/$defs/organization_schema"
        }
      }
    },
    "rewrite_suggestions": {
      "type": "array",
      "description": "Content rewrite suggestions requiring manual approval",
      "items": {
        "$ref": "#/$defs/rewrite_suggestion"
      }
    },
    "metadata": {
      "type": "object",
      "description": "Run metadata and statistics",
      "required": [
        "model",
        "prompt_version",
        "tokens_used",
        "processing_time_ms",
        "timestamp"
      ],
      "properties": {
        "model": {
          "type": "string",
          "description": "AI model used for analysis"
        },
        "prompt_version": {
          "type": "string",
          "description": "Version of prompt template used"
        },
        "tokens_used": {
          "type": "object",
          "properties": {
            "input": {
              "type": "integer",
              "minimum": 0
            },
            "output": {
              "type": "integer",
              "minimum": 0
            },
            "total": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "processing_time_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "Total processing time in milliseconds"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "UTC timestamp of analysis completion"
        },
        "site_id": {
          "type": "string",
          "description": "WordPress site identifier"
        },
        "post_id": {
          "type": "integer",
          "description": "WordPress post ID"
        },
        "content_type": {
          "type": "string",
          "enum": ["post", "page"],
          "description": "Type of content analyzed"
        },
        "word_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Word count of analyzed content"
        },
        "checks_performed": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of check IDs that were performed"
        }
      }
    }
  },
  "$defs": {
    "check": {
      "type": "object",
      "required": [
        "id",
        "title",
        "category",
        "verdict",
        "confidence",
        "explanation"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique check identifier"
        },
        "title": {
          "type": "string",
          "description": "Human-readable check title"
        },
        "category": {
          "type": "string",
          "enum": ["AEO", "GEO"],
          "description": "Category of check (AEO or GEO)"
        },
        "subcategory": {
          "type": "string",
          "description": "Subcategory within AEO/GEO"
        },
        "verdict": {
          "type": "string",
          "enum": ["pass", "partial", "fail"],
          "description": "Check result verdict"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Confidence score (0-1)"
        },
        "explanation": {
          "type": "string",
          "description": "Explanation of the verdict"
        },
        "suggestion": {
          "type": "string",
          "description": "Suggested improvement"
        },
        "highlights": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/highlight"
          }
        },
        "weight": {
          "type": "number",
          "minimum": 0,
          "description": "Weight of this check in overall score"
        },
        "provenance": {
          "type": "string",
          "description": "Source of the check result"
        }
      }
    },
    "highlight": {
      "type": "object",
      "required": [
        "node_ref",
        "text",
        "type"
      ],
      "properties": {
        "node_ref": {
          "type": "string",
          "description": "CSS selector or XPath to highlighted element"
        },
        "text": {
          "type": "string",
          "description": "Highlighted text content"
        },
        "type": {
          "type": "string",
          "enum": ["issue", "suggestion", "example"],
          "description": "Type of highlight"
        },
        "suggestion": {
          "type": "string",
          "description": "Suggested replacement or improvement"
        },
        "context": {
          "type": "string",
          "description": "Context around the highlight"
        },
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high"],
          "description": "Severity level for issues"
        }
      }
    },
    "rewrite_suggestion": {
      "type": "object",
      "required": [
        "id",
        "type",
        "original",
        "suggested",
        "reason"
      ],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "type": {
          "type": "string",
          "enum": ["sentence", "paragraph", "section", "full"],
          "description": "Scope of rewrite suggestion"
        },
        "original": {
          "type": "string",
          "description": "Original text content"
        },
        "suggested": {
          "type": "string",
          "description": "Suggested replacement text"
        },
        "reason": {
          "type": "string",
          "description": "Why this rewrite is suggested"
        },
        "applied": {
          "type": "boolean",
          "default": false,
          "description": "Whether the suggestion was applied"
        },
        "applied_at": {
          "type": "string",
          "format": "date-time",
          "description": "When the suggestion was applied"
        },
        "applied_by": {
          "type": "string",
          "description": "Who applied the suggestion"
        }
      }
    },
    "faq_schema": {
      "type": "object",
      "description": "FAQPage JSON-LD schema",
      "required": ["@context", "@type", "mainEntity"],
      "properties": {
        "@context": {
          "type": "string",
          "const": "https://schema.org"
        },
        "@type": {
          "type": "string",
          "const": "FAQPage"
        },
        "mainEntity": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["@type", "name", "acceptedAnswer"],
            "properties": {
              "@type": {
                "type": "string",
                "const": "Question"
              },
              "name": {
                "type": "string",
                "description": "The question text"
              },
              "acceptedAnswer": {
                "type": "object",
                "required": ["@type", "text"],
                "properties": {
                  "@type": {
                    "type": "string",
                    "const": "Answer"
                  },
                  "text": {
                    "type": "string",
                    "description": "The answer text"
                  }
                }
              }
            }
          }
        }
      }
    },
    "article_schema": {
      "type": "object",
      "description": "Article JSON-LD schema",
      "required": ["@context", "@type", "headline"],
      "properties": {
        "@context": {
          "type": "string",
          "const": "https://schema.org"
        },
        "@type": {
          "type": "string",
          "const": "Article"
        },
        "headline": {
          "type": "string",
          "description": "Article title"
        },
        "author": {
          "type": "object",
          "properties": {
            "@type": {
              "type": "string",
              "const": "Person"
            },
            "name": {
              "type": "string"
            }
          }
        },
        "datePublished": {
          "type": "string",
          "format": "date-time"
        },
        "dateModified": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "organization_schema": {
      "type": "object",
      "description": "Organization JSON-LD schema",
      "required": ["@context", "@type", "name"],
      "properties": {
        "@context": {
          "type": "string",
          "const": "https://schema.org"
        },
        "@type": {
          "type": "string",
          "const": "Organization"
        },
        "name": {
          "type": "string",
          "description": "Organization name"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "logo": {
          "type": "string",
          "format": "uri"
        }
      }
    }
  }
}
