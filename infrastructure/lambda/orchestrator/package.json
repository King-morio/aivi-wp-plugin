{
  "name": "aivi-orchestrator",
  "version": "1.0.0",
  "description": "AiVI Orchestrator Lambda Function",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "lint": "eslint *.js",
    "prepackage": "node -e \"require('fs').accessSync('token-counter.js')\"",
    "package:lambda": "tar -acf orchestrator.zip --exclude=\"*.zip\" --exclude=\"*.tmp.json\" --exclude=\"payload.tmp.json\" --exclude=\"poll.tmp.json\" --exclude=\"poll.response.tmp.json\" --exclude=\"response.tmp.json\" --exclude=\"response.json\" --exclude=\"orchestrator.code.url.txt\" --exclude=\"lambda_list.json\" --exclude=\"*.test.js\" -C . .",
    "package": "npm run package:lambda",
    "build": "npm run lint && npm test"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.454.0",
    "@aws-sdk/client-lambda": "^3.969.0",
    "@aws-sdk/client-s3": "^3.454.0",
    "@aws-sdk/client-secrets-manager": "^3.454.0",
    "@aws-sdk/client-sqs": "^3.454.0",
    "@aws-sdk/lib-dynamodb": "^3.969.0",
    "@aws-sdk/s3-request-presigner": "^3.454.0",
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "gpt-tokenizer": "^2.1.2",
    "htmlparser2": "^9.1.0",
    "jsonrepair": "^3.13.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "@types/node": "^20.9.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "typescript": "^5.2.2"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true,
      "jest": true,
      "es2021": true
    },
    "parserOptions": {
      "ecmaVersion": 2021
    },
    "rules": {
      "no-console": "off",
      "camelcase": "off"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
