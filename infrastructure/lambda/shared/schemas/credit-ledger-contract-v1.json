{
  "schema_version": "v1",
  "description": "Canonical credit pricing snapshot and ledger event contract for AiVI analysis billing and billable co-pilot generations.",
  "pricing_snapshot": {
    "pricing_version": "string",
    "requested_model": "string",
    "billable_model": "string",
    "rate_source": "catalog|default_fallback",
    "input_rate_usd_per_million": "number",
    "output_rate_usd_per_million": "number",
    "credit_multiplier": "integer",
    "context_window": "integer|null"
  },
  "usage_snapshot": {
    "input_tokens": "integer",
    "output_tokens": "integer",
    "weighted_tokens": "integer",
    "raw_cost_micros": "integer",
    "raw_cost_usd": "number",
    "credits_used": "integer"
  },
  "ledger_event": {
    "event_id": "string",
    "idempotency_key": "string",
    "account_id": "string",
    "site_id": "string",
    "run_id": "string|null",
    "event_type": "reservation|settlement|refund|adjustment",
    "status": "pending|settled|released|refunded|voided",
    "reason_code": "string (for example analysis_admission, analysis_completed, analysis_failed, copilot_generation, manual_credit_adjustment)",
    "pricing_snapshot": "pricing_snapshot",
    "usage_snapshot": "usage_snapshot|null",
    "amounts": {
      "reserved_credits": "integer",
      "settled_credits": "integer",
      "refunded_credits": "integer",
      "balance_before": "integer|null",
      "balance_after": "integer|null"
    },
    "created_at": "ISO-8601 string",
    "updated_at": "ISO-8601 string"
  }
}
