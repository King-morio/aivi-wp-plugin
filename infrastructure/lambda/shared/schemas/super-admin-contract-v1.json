{
  "version": "v1",
  "control_plane": {
    "app": "aivi-admin-console",
    "surface": "super_admin",
    "deployment_boundary": "outside_wordpress",
    "recommended_hosting": [
      "s3_cloudfront",
      "amplify_hosting"
    ]
  },
  "auth_model": {
    "provider": "aws_cognito",
    "required_claims": [
      "email",
      "cognito:groups"
    ],
    "required_groups": [
      "aivi-super-admin",
      "aivi-support",
      "aivi-finance"
    ],
    "mfa_required": true,
    "session_strategy": "hosted_ui_pkce"
  },
  "roles": {
    "super_admin": {
      "label": "Super Admin",
      "permissions": [
        "accounts.read",
        "accounts.write",
        "sites.read",
        "sites.write",
        "credits.read",
        "credits.adjust",
        "billing.read",
        "billing.reconcile",
        "webhooks.read",
        "webhooks.replay",
        "audit.read"
      ]
    },
    "support_operator": {
      "label": "Support Operator",
      "permissions": [
        "accounts.read",
        "sites.read",
        "credits.read",
        "billing.read",
        "billing.reconcile",
        "webhooks.read",
        "webhooks.replay",
        "audit.read"
      ]
    },
    "finance_operator": {
      "label": "Finance Operator",
      "permissions": [
        "accounts.read",
        "credits.read",
        "credits.adjust",
        "billing.read",
        "billing.reconcile",
        "webhooks.read",
        "audit.read"
      ]
    }
  },
  "payloads": {
    "account_list_row": {
      "required": [
        "account_id",
        "account_label",
        "plan_code",
        "subscription_status",
        "trial_status",
        "credits_remaining",
        "site_count",
        "updated_at"
      ]
    },
    "account_detail": {
      "required": [
        "account_id",
        "account_label",
        "plan",
        "credits",
        "usage",
        "subscription",
        "sites",
        "billing_health",
        "audit"
      ]
    },
    "site_detail": {
      "required": [
        "site_id",
        "blog_id",
        "connected_domain",
        "binding_status",
        "plugin_version",
        "last_analysis_at"
      ]
    },
    "credit_ledger_summary": {
      "required": [
        "included_remaining",
        "topup_remaining",
        "reserved_credits",
        "last_run_debit",
        "credits_used_this_month",
        "recent_events"
      ]
    },
    "adjustment_request": {
      "required": [
        "account_id",
        "operator_id",
        "reason",
        "adjustment_type",
        "credits_delta",
        "idempotency_key"
      ]
    },
    "support_diagnostics_summary": {
      "required": [
        "checkout_intents",
        "subscription_state",
        "topup_state",
        "webhook_health",
        "recent_failures"
      ]
    },
    "audit_event": {
      "required": [
        "event_id",
        "actor_id",
        "actor_role",
        "action",
        "target_type",
        "target_id",
        "reason",
        "created_at"
      ]
    }
  }
}
