{
  "schema_version": "v1",
  "description": "Canonical PayPal billing contract for AiVI subscriptions, top-up orders, and webhook reconciliation.",
  "plan_catalog": {
    "trial": {
      "code": "free_trial",
      "billing_type": "trial",
      "price_usd": 0,
      "included_credits": 15000,
      "site_limit": 1,
      "duration_days": 14
    },
    "starter": {
      "code": "starter",
      "billing_type": "subscription",
      "price_usd": 10,
      "included_credits": 60000,
      "site_limit": 1,
      "history_days": 30,
      "paypal_plan_env_key": "PAYPAL_PLAN_ID_STARTER"
    },
    "growth": {
      "code": "growth",
      "billing_type": "subscription",
      "price_usd": 22,
      "included_credits": 150000,
      "site_limit": 3,
      "history_days": 90,
      "intro_offer": {
        "type": "percent_off_first_cycle",
        "percent_off": 50
      },
      "paypal_plan_env_key": "PAYPAL_PLAN_ID_GROWTH"
    },
    "pro": {
      "code": "pro",
      "billing_type": "subscription",
      "price_usd": 59,
      "included_credits": 450000,
      "site_limit": 10,
      "history_days": 365,
      "paypal_plan_env_key": "PAYPAL_PLAN_ID_PRO"
    }
  },
  "topup_pack_catalog": {
    "topup_25k": {
      "code": "topup_25k",
      "billing_type": "topup",
      "credits": 25000,
      "price_usd": 7
    },
    "topup_100k": {
      "code": "topup_100k",
      "billing_type": "topup",
      "credits": 100000,
      "price_usd": 25
    },
    "topup_300k": {
      "code": "topup_300k",
      "billing_type": "topup",
      "credits": 300000,
      "price_usd": 69
    }
  },
  "checkout_intent": {
    "intent_id": "string",
    "intent_type": "subscription|topup|manage_billing",
    "account_id": "string",
    "site_id": "string",
    "plan_code": "string|null",
    "topup_pack_code": "string|null",
    "provider": "paypal",
    "provider_plan_id": "string|null",
    "provider_order_id": "string|null",
    "approval_url": "string",
    "return_url": "string",
    "cancel_url": "string",
    "created_at": "ISO-8601 string",
    "expires_at": "ISO-8601 string|null"
  },
  "subscription_record": {
    "subscription_id": "string",
    "account_id": "string",
    "provider": "paypal",
    "provider_subscription_id": "string",
    "plan_code": "starter|growth|pro",
    "status": "created|active|suspended|cancelled|expired|error",
    "current_period_start": "ISO-8601 string|null",
    "current_period_end": "ISO-8601 string|null",
    "cancel_at_period_end": "boolean",
    "created_at": "ISO-8601 string",
    "updated_at": "ISO-8601 string"
  },
  "topup_order_record": {
    "order_id": "string",
    "account_id": "string",
    "provider": "paypal",
    "provider_order_id": "string",
    "pack_code": "topup_25k|topup_100k|topup_300k",
    "credits": "integer",
    "status": "created|approved|captured|voided|error",
    "created_at": "ISO-8601 string",
    "updated_at": "ISO-8601 string"
  },
  "webhook_event_record": {
    "event_id": "string",
    "provider": "paypal",
    "provider_event_id": "string",
    "event_type": "string",
    "verification_status": "verified|invalid|error",
    "resource_type": "subscription|order|capture|other",
    "processed": "boolean",
    "processed_at": "ISO-8601 string|null",
    "created_at": "ISO-8601 string"
  },
  "env_keys": {
    "api_base": "PAYPAL_API_BASE",
    "client_id": "PAYPAL_CLIENT_ID",
    "client_secret": "PAYPAL_CLIENT_SECRET",
    "webhook_id": "PAYPAL_WEBHOOK_ID",
    "brand_name": "PAYPAL_BRAND_NAME",
    "return_url": "PAYPAL_RETURN_URL",
    "cancel_url": "PAYPAL_CANCEL_URL",
    "plan_ids": {
      "starter": "PAYPAL_PLAN_ID_STARTER",
      "growth": "PAYPAL_PLAN_ID_GROWTH",
      "pro": "PAYPAL_PLAN_ID_PRO"
    }
  }
}
