{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "DynamoDBAccess",
            "Effect": "Allow",
            "Action": [
                "dynamodb:GetItem",
                "dynamodb:PutItem",
                "dynamodb:UpdateItem",
                "dynamodb:Query"
            ],
            "Resource": [
                "arn:aws:dynamodb:eu-north-1:173471018175:table/aivi-runs-dev",
                "arn:aws:dynamodb:eu-north-1:173471018175:table/aivi-highlights-dev",
                "arn:aws:dynamodb:eu-north-1:173471018175:table/aivi-suggestions-dev"
            ]
        },
        {
            "Sid": "S3ArtifactsAccess",
            "Effect": "Allow",
            "Action": [
                "s3:GetObject",
                "s3:PutObject",
                "s3:DeleteObject"
            ],
            "Resource": [
                "arn:aws:s3:::aivi-artifacts-aivi-dev/*",
                "arn:aws:s3:::aivi-prompts-aivi-dev/*"
            ]
        },
        {
            "Sid": "S3BucketList",
            "Effect": "Allow",
            "Action": [
                "s3:ListBucket"
            ],
            "Resource": [
                "arn:aws:s3:::aivi-artifacts-aivi-dev",
                "arn:aws:s3:::aivi-prompts-aivi-dev"
            ]
        },
        {
            "Sid": "SQSAccess",
            "Effect": "Allow",
            "Action": [
                "sqs:ReceiveMessage",
                "sqs:DeleteMessage",
                "sqs:GetQueueAttributes",
                "sqs:SendMessage"
            ],
            "Resource": [
                "arn:aws:sqs:eu-north-1:173471018175:aivi-tasks-queue-dev",
                "arn:aws:sqs:eu-north-1:173471018175:aivi-rewrite-queue-dev"
            ]
        },
        {
            "Sid": "SecretsManagerRead",
            "Effect": "Allow",
            "Action": [
                "secretsmanager:GetSecretValue"
            ],
            "Resource": [
                "arn:aws:secretsmanager:eu-north-1:173471018175:secret:AVI_MISTRAL_API_KEY*"
            ]
        },
        {
            "Sid": "KMSDecrypt",
            "Effect": "Allow",
            "Action": [
                "kms:Decrypt",
                "kms:GenerateDataKey"
            ],
            "Resource": [
                "arn:aws:kms:eu-north-1:173471018175:key/eedf97ca-e7a6-46fe-a400-34d850ea8a08",
                "arn:aws:kms:eu-north-1:173471018175:key/b9435fcc-2a78-44b5-92ce-e422dabd8b2f"
            ]
        },
        {
            "Sid": "CloudWatchLogs",
            "Effect": "Allow",
            "Action": [
                "logs:CreateLogGroup",
                "logs:CreateLogStream",
                "logs:PutLogEvents"
            ],
            "Resource": [
                "arn:aws:logs:eu-north-1:173471018175:log-group:/aws/lambda/aivi-analyzer-worker-dev:*"
            ]
        }
    ]
}
