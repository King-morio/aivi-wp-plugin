{
  "name": "aivi-infrastructure",
  "version": "0.1.0",
  "description": "AiVI Infrastructure with AWS CDK",
  "main": "index.js",
  "scripts": {
    "build": "npm run lint && npm test",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
